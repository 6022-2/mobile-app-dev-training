<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <!-- 圆角 -->
            <corners android:radius="12dp" />
            <!-- 卡片背景色 -->
            <solid android:color="#FFFFFF" />
            <!-- 边框 -->
            <stroke
                android:width="1dp"
                android:color="#EEEEEE" />
        </shape>
    </item>
</selector>